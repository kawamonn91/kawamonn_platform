generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  account_name  String         @unique @db.VarChar(255)
  email         String         @unique @db.VarChar(255)
  password_hash String         @db.VarChar(255)
  two_factor_secret String?    @db.VarChar(255)
  role          String         @default("user") @db.VarChar(50)
  quota_bytes   BigInt         @default(21474836480)
  used_bytes    BigInt         @default(0)
  created_at    DateTime       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  files         File[]         @relation("FileOwner")
  shares        Share[]        @relation("ShareCreator")
  audit_logs    AuditLog[]     @relation("AuditActor")
  ssh_containers SshContainer[]
  password_reset_tokens PasswordResetToken[]
}

model File {
  id          String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  owner_id    String        @db.Uuid
  parent_id   String?       @db.Uuid
  name        String        @db.VarChar(255)
  size        BigInt
  mime_type   String        @db.VarChar(100)
  storage_key String?       @db.VarChar(500)
  version     Int           @default(1)
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  updated_at  DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  owner       User          @relation("FileOwner", fields: [owner_id], references: [id], onDelete: Cascade)
  parent      File?         @relation("FileHierarchy", fields: [parent_id], references: [id], onDelete: Cascade)
  children    File[]        @relation("FileHierarchy")
  versions    FileVersion[]
  shares      Share[]
}

model FileVersion {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  file_id        String   @db.Uuid
  storage_key    String   @db.VarChar(500)
  version_number Int
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  file           File     @relation(fields: [file_id], references: [id], onDelete: Cascade)
}

model Share {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  file_id       String    @db.Uuid
  token         String    @unique @db.VarChar(255)
  expires_at    DateTime? @db.Timestamptz(6)
  password_hash String?   @db.VarChar(255)
  max_downloads Int?
  created_by    String    @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  file          File      @relation(fields: [file_id], references: [id], onDelete: Cascade)
  creator       User      @relation("ShareCreator", fields: [created_by], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  actor_id    String?  @db.Uuid
  action      String   @db.VarChar(100)
  target_type String   @db.VarChar(50)
  target_id   String?  @db.Uuid
  metadata    Json?    @db.JsonB
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  actor       User?    @relation("AuditActor", fields: [actor_id], references: [id], onDelete: SetNull)
}

model SshContainer {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username        String    @db.VarChar(255)
  container_id    String?   @db.VarChar(255)
  image_tag       String    @db.VarChar(255)
  cpu_limit       String?   @db.VarChar(50)
  memory_limit    String?   @db.VarChar(50)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  last_started_at DateTime? @db.Timestamptz(6)
  user            User      @relation(fields: [username], references: [account_name], onDelete: Cascade, onUpdate: Cascade)
}

model OtpCode {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email      String   @db.VarChar(255)
  code       String   @db.VarChar(10)
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

model PasswordResetToken {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String   @unique @db.VarChar(256)
  expires_at DateTime @db.Timestamptz(6)
  used       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
