# Kawamonn Platform Environment Variables
SECRET_KEY=change_this_to_a_secure_random_string
SQLALCHEMY_DATABASE_URI=sqlite:////home/pi/hdd/ssh/kawamonn_platform/users.db
# Adjust path if not using SQLite or different location

# Mailgun Configuration
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.kawamonn.com

# Cloudflare Configuration
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_ZONE_ID=your_zone_id
CLOUDFLARE_ACCESS_TEAM_DOMAIN=kawamonn.cloudflareaccess.com

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Flask Settings
FLASK_ENV=production
